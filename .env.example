# Copy this file to backend/.env and fill in the values

# Database
DATABASE_URL=postgresql://karimvarela:localdev@localhost:5432/karimvarela_db

# JWT
JWT_SECRET=replace-with-long-random-secret-minimum-32-characters
JWT_EXPIRES_IN=7d

# Admin credentials
ADMIN_USERNAME=karim
# Generate with: node -e "const b = require('bcryptjs'); console.log(b.hashSync('yourpassword', 12))"
ADMIN_PASSWORD_HASH=$2b$12$examplehashhere

# Resume source
RESUME_GOOGLE_DOC_ID=1jV6xFhvbxmpQYsl_ara-9Yr-5XhnBLruDCnbjoYRo0E

# AI APIs
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AIza...

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://karimvarela.com

# App
NODE_ENV=development
PORT=4000
